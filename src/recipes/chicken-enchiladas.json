    {
      "kicker": "Step 1",
      "title": "Make the Enchilada Sauce",
      "checkboxLabel": "Sauce simmered and ready",
      "measurements": [
        { "item": "Olive oil", "qty": "2 tsp" },
        { "item": "Garlic", "qty": "2 cloves" },
        { "item": "Chili powder", "qty": "1½ tbsp" },
        { "item": "Cumin", "qty": "1½ tsp" },
        { "item": "Onion powder", "qty": "½ tsp" },
        { "item": "Garlic powder", "qty": "½ tsp" },
        { "item": "Salt", "qty": "¼ tsp" },
        { "item": "Cayenne", "qty": "a pinch" },
        { "item": "Tomato sauce", "qty": "15 oz can" },
        { "item": "Chicken broth", "qty": "½ cup" }
      ],
      "body": [
        {
          "type": "ul",
          "items": [
            "Heat <strong>2 tsp olive oil</strong> in a small saucepan over medium heat.",
            "Add <strong>minced garlic</strong>, cook stirring for <strong>30 seconds</strong> until fragrant.",
            "Add <strong>chili powder, cumin, onion powder, garlic powder, salt, and cayenne</strong>. Stir 30 seconds.",
            "Pour in <strong>tomato sauce</strong> and <strong>chicken broth</strong>. Stir to combine.",
            "Simmer on low for <strong>5–7 minutes</strong>, stirring occasionally."
          ]
        },
        {
          "type": "callout",
          "html": "<strong>Yield:</strong> About 2 cups of sauce. You'll use ½ cup in the filling and the rest for topping."
        }
      ]
    },
    {
      "kicker": "Step 2",
      "title": "Make the Filling",
      "checkboxLabel": "Filling cooked and ready",
      "measurements": [
        { "item": "Olive oil", "qty": "1 tbsp" },
        { "item": "Onion", "qty": "½ medium" },
        { "item": "Garlic", "qty": "2 cloves" },
        { "item": "Chicken", "qty": "2 cups shredded" },
        { "item": "Black beans", "qty": "15 oz can" },
        { "item": "Green chiles", "qty": "4 oz can" },
        { "item": "Chili powder", "qty": "1 tsp" },
        { "item": "Cumin", "qty": "1 tsp" },
        { "item": "Oregano", "qty": "½ tsp" },
        { "item": "Salt", "qty": "½ tsp" },
        { "item": "Enchilada sauce", "qty": "½ cup" }
      ],
      "body": [
        {
          "type": "ul",
          "items": [
            "Preheat oven to <strong>350°F</strong>.",
            "Heat <strong>1 tbsp olive oil</strong> in a large skillet over medium heat.",
            "Add <strong>diced onion</strong>, cook <strong>3–4 minutes</strong> until softened.",
            "Add <strong>garlic</strong>, cook <strong>30 seconds</strong>.",
            "Add <strong>shredded chicken, black beans, green chiles, chili powder, cumin, oregano, and salt</strong>. Stir to combine.",
            "Add <strong>½ cup enchilada sauce</strong>, stir and cook 1–2 minutes. Remove from heat."
          ]
        }
      ]
    },
    {
      "kicker": "Step 3",
      "title": "Assemble",
      "checkboxLabel": "Enchiladas rolled and in the dish",
      "measurements": [
        { "item": "Tortillas", "qty": "8" },
        { "item": "Cheese", "qty": "3 cups" },
        { "item": "Enchilada sauce", "qty": "remaining" }
      ],
      "body": [
        {
          "type": "ul",
          "items": [
            "Spread a thin layer of <strong>enchilada sauce</strong> on the bottom of a 9×13 baking dish.",
            "Lay a <strong>tortilla</strong> flat. Spoon filling down the center, top with a little <strong>cheese</strong>.",
            "<strong>Roll up</strong> and place <strong>seam-side down</strong> in the dish.",
            "Repeat for all <strong>8 tortillas</strong>.",
            "Pour remaining <strong>enchilada sauce</strong> over the top, then sprinkle with remaining <strong>cheese</strong>."
          ]
        },
        {
          "type": "callout",
          "html": "<strong>Make-ahead:</strong> Cover and refrigerate at this point for up to 1 day. Add 5–10 min to bake time if cold."
        }
      ]
    },
    {
      "kicker": "Step 4",
      "title": "Bake & Serve",
      "checkboxLabel": "Baked, cheese melted and bubbly",
      "body": [
        {
          "type": "ul",
          "items": [
            "Bake <strong>uncovered</strong> at 350°F for <strong>20–25 minutes</strong>, until cheese is melted and sauce is bubbling.",
            "Let rest <strong>5 minutes</strong> before serving."
          ]
        },
        { "type": "spacer" },
        {
          "type": "ul",
          "items": [
            "<strong>Optional toppings:</strong> sour cream, avocado, pico de gallo, fresh cilantro, chopped green onion"
          ]
        }
      ]
    }
